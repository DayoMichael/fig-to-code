{
  "name": "@fig2code/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "node --import tsx --test $(find src -name '*.test.ts')"
  },
  "dependencies": {
    "@fig2code/codegen": "workspace:*",
    "@fig2code/git-host": "workspace:*",
    "@fig2code/llm": "workspace:*",
    "@fig2code/repo": "workspace:*",
    "@fig2code/spec": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "hono": "^4.7.10"
  },
  "devDependencies": {
    "@fig2code/llm": "workspace:*",
    "tsx": "^4.19.4"
  }
}
